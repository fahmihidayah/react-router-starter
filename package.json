    "playwright": "1.59.1",
    "playwright-core": "1.59.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.0",
    "vite": "^7.1.0",
    "vite-tsconfig-paths": "^5.1.0",
    "vitest": "4.1.5"
  }
