{
  "name": "starter-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "db:push": "pnpm drizzle-kit push",
    "db:seed": "tsx seeds/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "db:drop": "drizzle-kit drop",
    "db:up": "drizzle-kit up",
    "db:reset": "pnpm db:drop && pnpm db:push && pnpm db:seed",
    "db:fresh": "pnpm db:push && pnpm db:seed",
    "db:backup": "tsx scripts/db-backup.ts",
    "db:restore": "tsx scripts/db-restore.ts",
    "db:snapshot": "drizzle-kit generate && pnpm db:backup",
    "db:inspect": "tsx scripts/db-inspect.ts",
    "db:validate": "pnpm db:check && pnpm typecheck",
    "db:setup": "pnpm db:generate && pnpm db:push && pnpm db:seed",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "biome:ci": "biome ci ."
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@lexical/list": "^0.44.0",
